          "format": 1,
          "rawSql": "SELECT\n    min(timestamp)         AS first_seen,\n    max(timestamp)         AS last_seen,\n    argMax(severity_text,  timestamp) AS aseverity,\n    argMax(title,          timestamp) AS atitle,\n    argMax(device_display, timestamp) AS adevice,\n    argMax(interface_name, timestamp) AS ainterface,\n    argMax(site_display,   timestamp) AS asite,\n    argMax(message,        timestamp) AS amessage,\n    argMax(resolution,     timestamp) AS ares\nFROM livenx_modeldb.Structured_Events\nWHERE alert_type IN ('INTERFACE_UTILIZATION','VOICE_VIDEO')\nGROUP BY alert_type, device_serial, interface_name, policy\nHAVING ares = false\n  AND match(asite,     '${site:pipe}')\n  AND match(adevice,   '${device:pipe}')\n  AND match(aseverity, '${severity:pipe}')\nORDER BY last_seen DESC\nLIMIT 100",
          "refId": "A"
