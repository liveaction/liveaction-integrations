            "uid": "PDEE91DDB90597936"
          },
          "format": 1,
          "rawSql": "SELECT\n    d.device_name,\n    COALESCE(s.site_name, 'Unknown') AS site_name,\n    CASE WHEN d.vendor_name = '' THEN 'Unknown' ELSE d.vendor_name END AS vendor_name,\n    d.vendor_model,\n    round(avgIf(h.value, h.metric = 'cpu.utilization_pct'), 1)    AS avg_cpu,\n    round(avgIf(h.value, h.metric = 'memory.utilization_pct'), 1) AS avg_mem\nFROM network_observability.devices d\nLEFT JOIN network_observability.sites s ON d.site_id = s.site_id\nLEFT JOIN network_observability.device_health_timeseries h\n    ON h.device_name = d.device_name\n    AND $__timeFilter(h.time)\nWHERE d.device_name != ''\n  AND match(COALESCE(s.site_name, ''), '${site:pipe}')\nGROUP BY d.device_name, site_name, vendor_name, d.vendor_model\nORDER BY avg_cpu DESC NULLS LAST\nLIMIT 50",
          "refId": "A"
        }
      ],
