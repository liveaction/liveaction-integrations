          "format": 1,
          "rawSql": "SELECT round(avg(bytes_per_sec), 0) AS value\nFROM (\n    SELECT\n        toStartOfInterval(time, INTERVAL 5 MINUTE) AS t,\n        sum(sum_octets) / 300 AS bytes_per_sec\n    FROM network_observability.basic_ipfix_flows_5m\n    WHERE $__timeFilter(time)\n    GROUP BY t\n)",
          "refId": "A"
        }
      ],
