          },
          "format": 1,
          "rawSql": "SELECT\n    asite AS site,\n    countIf(aseverity = 'Critical') AS Critical,\n    countIf(aseverity = 'Warning')  AS Warning,\n    countIf(aseverity = 'Info')     AS Info\nFROM (\n    SELECT\n        alert_type, device_serial, interface_name, policy,\n        argMax(resolution,    timestamp) AS ares,\n        argMax(site_display,  timestamp) AS asite,\n        argMax(severity_text, timestamp) AS aseverity\n    FROM livenx_modeldb.Structured_Events\n    WHERE alert_type IN ('DEVICE_DOWN','DEVICE_MEM','DEVICE_CPU','INTERFACE_UTILIZATION','VOICE_VIDEO')\n    GROUP BY alert_type, device_serial, interface_name, policy\n    HAVING ares = false\n)\nWHERE asite != ''\n  AND match(asite, '${site:pipe}')\nGROUP BY asite\nORDER BY (Critical + Warning + Info) DESC\nLIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Active Alerts by Site",
      "type": "barchart"
